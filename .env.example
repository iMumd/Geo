# ═══════════════════════════════════════════════════════════════
# Geo Protection Bot - Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Bot Settings
# ─────────────────────────────────────────────────────────────
BOT_NAME=Geo
BOT_USERNAME=F_FFBot
BOT_TOKEN=your_bot_token_here

# ─────────────────────────────────────────────────────────────
# Developer Settings (God Mode)
# ─────────────────────────────────────────────────────────────
DEVELOPER_ID=your_telegram_user_id
GOD_MODE=true
GOD_STATUS=Mythic

# ─────────────────────────────────────────────────────────────
# Telegram API (Mandatory)
# ─────────────────────────────────────────────────────────────
API_ID=your_api_id
API_HASH=your_api_hash

# ─────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///geo.db
DB_AUTO_CLEAN=true
DB_BACKUP_INTERVAL=3600

# ─────────────────────────────────────────────────────────────
# Redis Cache (Optional but recommended)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# ─────────────────────────────────────────────────────────────
# Performance Settings
# ─────────────────────────────────────────────────────────────
WORKERS=8
MAX_LOAD=10000
CONNECTION_POOL_SIZE=100
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────
# Security Settings
# ─────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_random_secret_key_here
ENABLE_ANTISPAM=true
ENABLE_FLOOD_PROTECTION=true
MAX_MESSAGE_LENGTH=4096
RATE_LIMIT=30

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=geo.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
ENABLE_DEBUG=false

# ─────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────
ENABLE_WELCOME=true
ENABLE_GOODBYE=true
ENABLE_WARNINGS=true
ENABLE_LOCKS=true
ENABLE_FILTERS=true
ENABLE_REPORTS=true
ENABLE_STAFF=true
ENABLE_GLOBAL_BANS=true
ENABLE_APPROVALS=true

# ─────────────────────────────────────────────────────────────
# Default Protection Settings
# ─────────────────────────────────────────────────────────────
DEFAULT_WARNS=3
DEFAULT_ANTISPAM_TIME=100
DEFAULT_FLOOD_TIME=5
DEFAULT_MUTE_TIME=60
DEFAULT_RAID_PROTECTION_TIME=300

# ─────────────────────────────────────────────────────────────
# Language Settings
# ─────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,ar,ru,tr,de,pt,id,hi,zh

# ─────────────────────────────────────────────────────────────
# Message Templates
# ─────────────────────────────────────────────────────────────
WELCOME_MESSAGE=Welcome {user} to {chat}!
GOODBYE_MESSAGE={user} left {chat}
BAN_MESSAGE=User {user} has been banned
MUTE_MESSAGE=User {user} has been muted
WARN_MESSAGE={user} has been warned ({count}/{limit})

# ─────────────────────────────────────────────────────────────
# Advanced Settings
# ─────────────────────────────────────────────────────────────
AUTO_DEL_SERVICE_MESSAGES=false
AUTO_PROMOTE_ADMINS=false
AUTO_LOCK_NEW_MEMBERS=false
STRICT_MODE=false
PREFER_BOT_OVER_HUMAN=true